{
  "name": "mcptrace",
  "version": "0.1.0",
  "description": "Flight recorder and replay debugger for MCP stdio servers.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcptrace": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "trace",
    "debugger",
    "stdio",
    "json-rpc",
    "claude",
    "agent"
  ],
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
