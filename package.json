{
  "name": "@fjlkasdg45345/mcptrace",
  "version": "0.1.0",
  "description": "Flight recorder and replay debugger for MCP stdio servers.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teee32/mcptrace.git"
  },
  "bugs": {
    "url": "https://github.com/teee32/mcptrace/issues"
  },
  "homepage": "https://github.com/teee32/mcptrace#readme",
  "bin": {
    "mcptrace": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "npm run build",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "trace",
    "debugger",
    "stdio",
    "json-rpc",
    "claude",
    "agent"
  ],
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
